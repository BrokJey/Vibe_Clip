<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Разрешаем cleartext для всех доменов (локальная разработка).
         Для продакшена перевести на HTTPS и убрать base-config. -->
    <base-config cleartextTrafficPermitted="true" />

    <!-- Дополнительно оставляем явные домены, если понадобится сузить позже. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.1.18</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>

